# Public API domain handled by Caddy. This should point DNS A/AAAA records to the VPS.
API_DOMAIN=api.your-domain.com

# Public frontend origins allowed to call the API. Add your deployed web URL here.
CORS_ORIGINS=https://your-web-domain.com,https://your-netlify-site.netlify.app,http://localhost:3000,http://127.0.0.1:3000

NEUROAD_MAX_UPLOAD_MB=200
NEUROAD_MAX_SOURCE_SECONDS=600
NEUROAD_MAX_ANALYSIS_SECONDS=180

# Optional YouTube settings.
# YOUTUBE_API_KEY=
# YTDLP_COOKIES_FILE=/data/neuroad/cookies.txt
